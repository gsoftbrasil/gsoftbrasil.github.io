# Copie este arquivo para `.env` na raiz do repositório e preencha os valores.
# O arquivo `.env` NÃO deve ser commitado (já está no .gitignore).

# Obrigatório — chave da API Cursor (Dashboard → Integrations / API Keys)
CURSOR_API_KEY=cursor_sua_chave_aqui

# Opcional — modelo do Cursor SDK (padrão: auto)
# CURSOR_MODEL=composer-2.5
